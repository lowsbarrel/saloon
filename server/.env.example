# Saloon server configuration
# Copy to .env and adjust as needed. All variables are prefixed with SALOON_.

# ── Server ─────────────────────────────────────────────────────────────────
# SALOON_HOST=0.0.0.0
# SALOON_PORT=8000
# SALOON_LOG_LEVEL=warning

# ── Channels ───────────────────────────────────────────────────────────────
# SALOON_MAX_CHANNELS=100
# SALOON_MAX_USERS_PER_CHANNEL=20

# ── Rate limits (per IP) ──────────────────────────────────────────────────
# SALOON_RATE_JOIN_MAX=10
# SALOON_RATE_JOIN_WINDOW=60.0
# SALOON_RATE_USERNAME_MAX=10
# SALOON_RATE_USERNAME_WINDOW=60.0
# SALOON_RATE_CREATE_CHANNEL_MAX=5
# SALOON_RATE_CREATE_CHANNEL_WINDOW=60.0
# SALOON_RATE_WS_MAX=20
# SALOON_RATE_WS_WINDOW=60.0
# SALOON_RATE_CHAT_MAX=5
# SALOON_RATE_CHAT_WINDOW=5.0

# ── WebSocket ──────────────────────────────────────────────────────────────
# SALOON_MAX_WS_MESSAGE_SIZE=65536
# SALOON_MAX_CHAT_LENGTH=2000

# ── Argon2id password hashing ─────────────────────────────────────────────
# SALOON_ARGON2_TIME_COST=3
# SALOON_ARGON2_MEMORY_COST=65536
# SALOON_ARGON2_PARALLELISM=4
# SALOON_ARGON2_HASH_LEN=32

# ── Username generation ───────────────────────────────────────────────────
# SALOON_USERNAME_MAX_RETRIES=50
